# Environment variables for Smart Academic Platform Frontend
# Copy this file to .env.local for local development
# For production, set these variables in your hosting platform (Vercel)

# Backend API URL (local development)
NEXT_PUBLIC_API_URL=http://localhost:3001

# AI Service URL (local development)
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:5000

# Production URLs (example)
# NEXT_PUBLIC_API_URL=https://smart-academic-backend.onrender.com
# NEXT_PUBLIC_AI_SERVICE_URL=https://smart-academic-ai.onrender.com

# Optional: Add any other public environment variables here
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=UA-XXXXX-Y