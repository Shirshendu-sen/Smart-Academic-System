// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(100)
  email      String    @unique @db.VarChar(100)
  password   String    @db.VarChar(255)
  role       String    @default("student") @db.VarChar(20)
  avatarUrl  String?   @map("avatar_url") @db.VarChar(255)
  createdAt  DateTime  @default(now()) @map("created_at")
  
  // Relationships
  coursesCreated Course[]     @relation("InstructorCourses")
  enrollments    Enrollment[]
  progress       Progress[]
  quizAttempts   QuizAttempt[]
  certificates   Certificate[]
  
  @@map("users")
}

model Course {
  id           Int        @id @default(autoincrement())
  title        String     @db.VarChar(200)
  description  String?
  instructorId Int        @map("instructor_id")
  thumbnailUrl String?    @map("thumbnail_url") @db.VarChar(255)
  isPublished  Boolean    @default(false) @map("is_published")
  createdAt    DateTime   @default(now()) @map("created_at")
  
  // Relationships
  instructor User         @relation("InstructorCourses", fields: [instructorId], references: [id])
  lessons    Lesson[]
  enrollments Enrollment[]
  certificates Certificate[]
  
  @@map("courses")
}

model Lesson {
  id         Int       @id @default(autoincrement())
  courseId   Int       @map("course_id")
  title      String    @db.VarChar(200)
  content    String?
  videoUrl   String?   @map("video_url") @db.VarChar(255)
  orderIndex Int?      @map("order_index")
  createdAt  DateTime  @default(now()) @map("created_at")
  
  // Relationships
  course   Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress Progress[]
  quiz     Quiz?
  
  @@map("lessons")
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  studentId Int      @map("student_id")
  courseId  Int      @map("course_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")
  
  // Relationships
  student User   @relation(fields: [studentId], references: [id])
  course  Course @relation(fields: [courseId], references: [id])
  
  @@unique([studentId, courseId])
  @@map("enrollments")
}

model Progress {
  id          Int      @id @default(autoincrement())
  studentId   Int      @map("student_id")
  lessonId    Int      @map("lesson_id")
  completed   Boolean  @default(false)
  completedAt DateTime? @map("completed_at")
  
  // Relationships
  student User   @relation(fields: [studentId], references: [id])
  lesson  Lesson @relation(fields: [lessonId], references: [id])
  
  @@map("progress")
}

model Quiz {
  id        Int      @id @default(autoincrement())
  lessonId  Int      @unique @map("lesson_id")
  questions Json     // array of {question, options[], correct_answer, explanation}
  createdAt DateTime @default(now()) @map("created_at")
  
  // Relationships
  lesson        Lesson        @relation(fields: [lessonId], references: [id])
  quizAttempts  QuizAttempt[]
  
  @@map("quizzes")
}

model QuizAttempt {
  id         Int      @id @default(autoincrement())
  quizId     Int      @map("quiz_id")
  studentId  Int      @map("student_id")
  score      Int?
  answers    Json?    // student's answers
  attemptedAt DateTime @default(now()) @map("attempted_at")
  
  // Relationships
  quiz    Quiz @relation(fields: [quizId], references: [id])
  student User @relation(fields: [studentId], references: [id])
  
  @@map("quiz_attempts")
}

model Certificate {
  id        Int      @id @default(autoincrement())
  studentId Int      @map("student_id")
  courseId  Int      @map("course_id")
  issuedAt  DateTime @default(now()) @map("issued_at")
  certUrl   String?  @map("cert_url") @db.VarChar(255)
  
  // Relationships
  student User   @relation(fields: [studentId], references: [id])
  course  Course @relation(fields: [courseId], references: [id])
  
  @@map("certificates")
}